# Example environment variables for Lightning Miner
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ===========================
# Server Configuration
# ===========================
HOST=localhost
PORT=8080
NODE_ENV=development

# ===========================
# Bitcoin / Lightning Network
# ===========================
# Network type: mainnet or testnet (use testnet first!)
BITCOIN_NETWORK=testnet

# Lightning Node connection
LIGHTNING_NODE_URL=http://localhost:8080
LIGHTNING_NODE_TOKEN=your_lightning_node_token

# LND (Lightning Network Daemon) settings
LND_HOST=localhost:10009
LND_MACAROON=your_lnd_macaroon_hex
LND_CERT=your_lnd_tls_cert_base64

# ===========================
# BTCPay Server
# ===========================
BTCPAY_URL=https://your-btcpay-instance.com
BTCPAY_API_KEY=your_btcpay_api_key
BTCPAY_STORE_ID=your_btcpay_store_id
BTCPAY_TOKEN=your_btcpay_token

# ===========================
# Mining Pool
# ===========================
MINING_POOL_URL=stratum+tcp://btc.braiins.com:3333
WALLET_ADDRESS=your_bitcoin_wallet_address

# ===========================
# Database Configuration (Optional)
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lightning_miner
DB_USER=your_database_user
DB_PASS=your_database_password

# ===========================
# Security
# ===========================
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change_this_to_a_strong_random_secret
API_KEY=your_api_key

# ===========================
# Optional Settings
# ===========================
DEBUG=false
LOG_LEVEL=info
