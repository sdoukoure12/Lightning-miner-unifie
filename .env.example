# Example environment variables for Lightning Miner

# Networking
HOST=localhost
PORT=8080

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# API Keys
API_KEY=your_api_key

# Miner Settings
MINING_POOL_URL=your_mining_pool_url
WALLET_ADDRESS=your_wallet_address

# Optional Settings
DEBUG=true
LOG_LEVEL=info
