# Example environment variables for Lightning Miner

# Application
NODE_ENV=development
API_PORT=3000

# Networking
HOST=localhost
PORT=8080

# Database Configuration
MONGO_URI=mongodb+srv://user:your_secure_password_here@cluster/database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# BTCPay Server
BTCPAY_SERVER=https://your-btcpay-server.example.com
BTCPAY_API_KEY=your_btcpay_api_key
BTCPAY_TOKEN=your_btcpay_token

# Lightning Network (LND)
LN_NETWORK=mainnet
LND_HOST=localhost:10009
LND_MACAROON=your_lnd_macaroon_hex
LND_CERT=your_lnd_tls_cert

# API Keys
API_KEY=your_api_key_here

# JWT
# Generate a strong secret with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=7d

# Miner Settings
MINING_POOL_URL=your_mining_pool_url

# Wallet Configuration
# Option 1: point to a JSON file containing an array of wallet objects
#   (see wallets.example.json for the expected format)
WALLETS_CONFIG_FILE=/path/to/wallets.json

# Option 2: inline wallet definitions as JSON objects (one per env var)
# WALLET_1={"name":"My Lightning Wallet","address":"lnbc1...","type":"lightning","pool":"braiins","worker":"rig1","threshold":0.0005}
# WALLET_2={"name":"My On-Chain Wallet","address":"bc1q...","type":"onchain","pool":"mara","worker":"rig2","threshold":0.005}

# Runtime config file path for config backups
CONFIG_FILE=/sdcard/lightning-miner-config.json

# Optional Settings
DEBUG=true
LOG_LEVEL=info
